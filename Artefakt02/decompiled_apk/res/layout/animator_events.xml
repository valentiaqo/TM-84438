<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="1" android:id="@id/container" android:layout_width="-1" android:layout_height="-1"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="0" android:layout_width="-1" android:layout_height="-2">
        <Button android:id="@id/startButton" android:layout_width="-2" android:layout_height="-2" android:text="Play" android:contentDescription="Play" />
        <Button android:id="@id/cancelButton" android:layout_width="-2" android:layout_height="-2" android:text="Cancel" android:contentDescription="Cancel" />
        <Button android:id="@id/endButton" android:layout_width="-2" android:layout_height="-2" android:text="End" android:contentDescription="End" />
        <CheckBox android:id="@id/endCB" android:layout_width="-2" android:layout_height="-2" android:text="End Immediately" android:contentDescription="End Immediately" />
    </LinearLayout>
    <LinearLayout android:orientation="0" android:layout_width="-1" android:layout_height="-2">
        <TextView android:layout_width="-2" android:layout_height="-2" android:text="Sequencer Events:   " android:contentDescription="Sequencer Events:   " />
        <TextView android:id="@id/startText" android:layout_width="-2" android:layout_height="-2" android:text="Start   " android:contentDescription="Start   " />
        <TextView android:id="@id/repeatText" android:layout_width="-2" android:layout_height="-2" android:text="Repeat   " android:contentDescription="Repeat   " />
        <TextView android:id="@id/cancelText" android:layout_width="-2" android:layout_height="-2" android:text="Cancel   " android:contentDescription="Cancel   " />
        <TextView android:id="@id/endText" android:layout_width="-2" android:layout_height="-2" android:text="End" android:contentDescription="End" />
    </LinearLayout>
    <LinearLayout android:orientation="0" android:layout_width="-1" android:layout_height="-2">
        <TextView android:layout_width="-2" android:layout_height="-2" android:text="Animator Events:   " android:contentDescription="Animator Events:   " />
        <TextView android:id="@id/startTextAnimator" android:layout_width="-2" android:layout_height="-2" android:text="Start   " android:contentDescription="Start   " />
        <TextView android:id="@id/repeatTextAnimator" android:layout_width="-2" android:layout_height="-2" android:text="Repeat   " android:contentDescription="Repeat   " />
        <TextView android:id="@id/cancelTextAnimator" android:layout_width="-2" android:layout_height="-2" android:text="Cancel   " android:contentDescription="Cancel   " />
        <TextView android:id="@id/endTextAnimator" android:layout_width="-2" android:layout_height="-2" android:text="End" android:contentDescription="End" />
    </LinearLayout>
</LinearLayout>
