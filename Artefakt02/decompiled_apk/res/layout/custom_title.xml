<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="1" android:id="@id/screen" android:layout_width="-1" android:layout_height="-1"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:layout_width="-1" android:layout_height="-2" android:baselineAligned="false">
        <EditText android:layout_gravity="0x10" android:id="@id/left_text_edit" android:layout_width="-2" android:layout_height="-2" android:text="@string/custom_title_left" android:maxEms="10" android:minEms="10" android:contentDescription="@string/custom_title_left" />
        <Button android:layout_gravity="0x10" android:id="@id/left_text_button" android:layout_width="-2" android:layout_height="-2" android:text="@string/custom_title_left_button" android:contentDescription="@string/custom_title_left_button" />
    </LinearLayout>
    <LinearLayout android:layout_width="-1" android:layout_height="-2" android:baselineAligned="false">
        <EditText android:layout_gravity="0x10" android:id="@id/right_text_edit" android:layout_width="-2" android:layout_height="-2" android:text="@string/custom_title_right" android:maxEms="10" android:minEms="10" android:contentDescription="@string/custom_title_right" />
        <Button android:layout_gravity="0x10" android:id="@id/right_text_button" android:layout_width="-2" android:layout_height="-2" android:text="@string/custom_title_right_button" android:contentDescription="@string/custom_title_right_button" />
    </LinearLayout>
</LinearLayout>
