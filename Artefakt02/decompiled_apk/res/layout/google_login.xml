<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="1" android:layout_width="-1" android:layout_height="-1"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <Button android:id="@id/login" android:layout_width="-2" android:layout_height="-2" android:text="@string/googlelogin_login" android:contentDescription="@string/googlelogin_login" />
    <Button android:id="@id/bad_login" android:layout_width="-2" android:layout_height="-2" android:text="@string/googlelogin_bad_login" android:contentDescription="@string/googlelogin_bad_login" />
    <Button android:id="@id/clear" android:layout_width="-2" android:layout_height="-2" android:text="@string/googlelogin_clear" android:contentDescription="@string/googlelogin_clear" />
    <TextView android:id="@id/username_label" android:visibility="2" android:layout_width="-1" android:layout_height="-2" android:text="@string/googlelogin_user" android:contentDescription="@string/googlelogin_user" />
    <TextView android:id="@id/username" android:visibility="2" android:layout_width="-1" android:layout_height="-2" android:text="@string/google_login_username_text" android:contentDescription="@string/google_login_username_text" />
</LinearLayout>
