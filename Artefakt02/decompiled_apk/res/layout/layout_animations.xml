<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="1" android:id="@id/parent" android:layout_width="-1" android:layout_height="-2"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="0" android:layout_width="-1" android:layout_height="-1">
        <Button android:id="@id/addNewButton" android:layout_width="-2" android:layout_height="-2" android:text="Add Button" android:contentDescription="Add Button" />
        <CheckBox android:id="@id/customAnimCB" android:layout_width="-2" android:layout_height="-2" android:text="Custom Animations" android:contentDescription="Custom Animations" />
    </LinearLayout>
    <LinearLayout android:orientation="0" android:layout_width="-1" android:layout_height="-2">
        <CheckBox android:id="@id/appearingCB" android:layout_width="-2" android:layout_height="-2" android:checked="true" android:text="In" android:contentDescription="In" />
        <CheckBox android:id="@id/disappearingCB" android:layout_width="-2" android:layout_height="-2" android:checked="true" android:text="Out" android:contentDescription="Out" />
    </LinearLayout>
    <LinearLayout android:orientation="0" android:layout_width="-1" android:layout_height="-2">
        <CheckBox android:id="@id/changingAppearingCB" android:layout_width="-2" android:layout_height="-2" android:checked="true" android:text="Changing-In" android:contentDescription="Changing-In" />
        <CheckBox android:id="@id/changingDisappearingCB" android:layout_width="-2" android:layout_height="-2" android:checked="true" android:text="Changing-Out" android:contentDescription="Changing-Out" />
    </LinearLayout>
</LinearLayout>
